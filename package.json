{
  "name": "@infolang/ai-sdk",
  "version": "0.1.0",
  "description": "InfoLang semantic memory for the Vercel AI SDK — a LanguageModelMiddleware that recalls context before generation and remembers the exchange after, plus memory tools.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "InfoLang <engineering@infolang.ai>",
  "homepage": "https://infolang.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InfoLang-Inc/infolang-ai-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/InfoLang-Inc/infolang-ai-sdk/issues"
  },
  "keywords": [
    "infolang",
    "semantic-memory",
    "vercel",
    "ai-sdk",
    "middleware",
    "rag",
    "memory",
    "llm"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:live": "INFOLANG_LIVE=1 vitest run"
  },
  "peerDependencies": {
    "@infolang/sdk": "^0.2",
    "ai": ">=5 <8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@infolang/sdk": "^0.2.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "ai": "^7.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  }
}
