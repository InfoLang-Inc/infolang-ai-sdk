# Model provider (OpenAI is used by the template; swap in any AI SDK provider).
OPENAI_API_KEY=sk-...
# Optional: override the default model.
OPENAI_MODEL=gpt-4o-mini

# InfoLang managed cloud key. Reads/writes are scoped to the key's workspace
# (tenant); the middleware pins each user to their own namespace (bank).
INFOLANG_API_KEY=il_live_...
# Optional: target a specific workspace when the key allows several.
# INFOLANG_WORKSPACE=your-workspace-id
